# Copy this file to .env and fill in your values
# Never commit .env to version control

# PostgreSQL (Supabase in production)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# JWT
JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-string

# Groq LLM
GROQ_API_KEY=gsk_your_groq_api_key_here

# ML Inference (Hugging Face Space URL — leave blank to use mock fallback)
ML_API_URL=https://your-username-insurance-fraud-ml.hf.space

# Redis (optional for future caching)
REDIS_URL=redis://redis:6379/0

# CORS — comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Environment
ENVIRONMENT=development
REQUIRE_HTTPS=false

# Auto-run Alembic migrations on container startup
RUN_MIGRATIONS=true
