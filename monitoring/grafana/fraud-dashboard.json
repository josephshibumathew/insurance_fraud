{
  "title": "Fraud Platform API",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Throughput",
      "targets": [{ "expr": "rate(http_requests_total[1m])" }]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))" }]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m])" }]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
