# Shared example for Docker Compose and application services.
# Copy to .env.dev / .env.staging / .env.prod and replace placeholders.

POSTGRES_DB=fraud_db
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=change-this-password

DATABASE_URL=postgresql://fraud_user:change-this-password@db:5432/fraud_db
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-string
GROQ_API_KEY=gsk_your_groq_api_key_here

BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000"]
ENVIRONMENT=production
REQUIRE_HTTPS=false
RUN_MIGRATIONS=true

# Local compose can point at ml-mock; production should use your HF Space URL.
ML_API_URL=http://ml-mock:7860

# Build-time API URL used by frontend Docker image.
FRONTEND_API_URL=http://localhost:8000/api/v1